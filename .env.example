LI_EMAIL=your@email.com
LI_PASSWORD=yourpassword

# Comma-separated search queries
SEARCH_QUERIES=java developer hiring,java spring boot hiring,senior java engineer opportunity,backend java developer,java developer OPT sponsorship

# How far back to look: supports 1d, 12h, 1d3h, 2d12h (plain integer treated as days)
DAYS_BACK=1d

# Max posts to collect per query per run
MAX_POSTS_PER_QUERY=20
